# Copy to .env.local and fill from Supabase Dashboard → Project Settings → API

# Public (safe in the browser bundle)
NEXT_PUBLIC_ROOT_DOMAIN=glanzo.app
# Local dev: set NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000 in .env.local
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server only — never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CRON_SECRET=generate-a-long-random-secret
# Optional — omit locally to use .dev-emails log adapter
RESEND_API_KEY=
EMAIL_FROM=Glanzo <termine@glanzo.app>
