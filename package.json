{
  "name": "glanzo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --use-system-ca ./node_modules/next/dist/bin/next dev --turbopack",
    "build": "node scripts/run-build.mjs",
    "start": "next start",
    "lint": "eslint .",
    "lint:all": "eslint . && pnpm db:types:check",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test:rls": "vitest run tests/rls",
    "test:security": "vitest run tests/security",
    "test:unit": "vitest run tests/unit",
    "test:static": "node scripts/check-public-env.mjs && node scripts/check-service-role-imports.mjs && node scripts/check-no-console-log.mjs && node scripts/check-no-hex.mjs && node scripts/check-use-server-exports.mjs && node scripts/check-route-budgets.mjs",
    "test:secure": "node --use-system-ca scripts/run-test-secure.mjs",
    "test:e2e": "playwright test",
    "test:e2e:dev": "playwright test --config=playwright.config.ts",
    "test:e2e:prod": "playwright test --config=playwright.prod.config.ts",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push:test": "node --use-system-ca scripts/db-push-test.mjs",
    "db:reset:test": "node --use-system-ca scripts/db-reset-test.mjs",
    "db:types": "supabase gen types typescript --linked --schema public > src/types/database.types.ts",
    "db:diff": "supabase db diff -f",
    "db:types:check": "node scripts/check-db-types.mjs",
    "jobs:dispatch": "node scripts/dispatch-notifications.mjs",
    "test:integration": "vitest run tests/integration",
    "verify": "pnpm lint && pnpm typecheck && pnpm test:unit && pnpm test:static && pnpm db:types:check"
  },
  "dependencies": {
    "@date-fns/tz": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.78.0",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@next/eslint-plugin-next": "^15.5.19",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.3.3",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "supabase": "^2.105.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
